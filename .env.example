# 微信公众号配置
WECHAT_APPID=your_appid_here
WECHAT_APPSECRET=your_appsecret_here

# 魔搭 ModelScope API Key（国内可直接访问，免费，推荐）
# 获取地址：https://modelscope.cn/my/myaccesstoken
MODELSCOPE_API_KEY=your_modelscope_token_here

# Gemini API Key（需代理，可选）
# GEMINI_API_KEY=your_gemini_key_here

# Gemini Pro 代理（可选，默认 http://127.0.0.1:7890）
# GEMINI_PRO_PROXY=http://127.0.0.1:7890

# 默认作者（可选，默认为"龙虾"）
WECHAT_DEFAULT_AUTHOR=龙虾
